{
	"$schema": "https://biomejs.dev/schemas/2.4.11/schema.json",
	"vcs": {
		"enabled": false,
		"clientKind": "git",
		"useIgnoreFile": false
	},
	"files": {
		"ignoreUnknown": false,
		"includes": [
			"**/*.js",
			"**/*.cjs",
			"**/*.mjs",
			"**/*.jsx",
			"**/*.ts",
			"**/*.cts",
			"**/*.mts",
			"**/*.tsx",
			"**/*.json",
			"**/*.jsonc",
			"**/*.css",
			"**/*.html",
			"!**/dist",
			"!**/.vinxi",
			"!**/.wrangler",
			"!**/coverage",
			"!**/worker-configuration.d.ts",
			"!**/src/routeTree.gen.ts"
		]
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab"
	},
	"assist": { "actions": { "source": { "organizeImports": "on" } } },
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true
		}
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "double"
		}
	},
	"css": {
		"parser": {
			"tailwindDirectives": true
		}
	}
}
