{
  "name": "kpm-sh",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "zsh -lc 'set -a; source .env; set +a; vite dev --port 3000'",
    "dev:prod": "zsh -lc 'set -a; source .env; set +a; KV_READ_ONLY_CACHE=true vite dev --port 3000'",
    "build": "vite build",
    "serve": "vite preview",
    "test": "vitest run --passWithNoTests",
    "format": "biome format",
    "lint": "biome lint",
    "check": "biome check",
    "deploy": "wrangler deploy",
    "og": "npx vite-node --config vite.og.config.ts src/lib/open-graph/index.tsx"
  },
  "dependencies": {
    "@hackernoon/pixel-icon-library": "^1.0.6",
    "@markdoc/markdoc": "^0.5.7",
    "@resvg/resvg-js": "^2.6.2",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/react-devtools": "^0.10.2",
    "@tanstack/react-router": "^1.168.18",
    "@tanstack/react-router-devtools": "^1.166.13",
    "@tanstack/react-router-ssr-query": "^1.166.11",
    "@tanstack/react-start": "^1.167.32",
    "@tanstack/router-plugin": "^1.167.18",
    "@types/js-yaml": "^4.0.9",
    "@types/prismjs": "^1.26.6",
    "effect": "^3.21.0",
    "fast-xml-parser": "^5.5.11",
    "js-yaml": "^4.1.1",
    "lucide-react": "^1.8.0",
    "mermaid": "^11.14.0",
    "prismjs": "^1.30.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "satori": "^0.26.0",
    "slugify": "^1.6.9"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.11",
    "@cloudflare/vite-plugin": "^1.31.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "jsdom": "^29.0.2",
    "typescript": "^6.0.2",
    "vite": "^8.0.8",
    "vite-node": "^6.0.0",
    "vitest": "^4.1.4",
    "web-vitals": "^5.2.0",
    "wrangler": "^4.81.1"
  }
}
