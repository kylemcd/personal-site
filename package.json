{
	"name": "kpm-sh",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "zsh -lc 'set -a; source .env; set +a; vite dev --host 0.0.0.0 --port 3000'",
		"dev:sandbox": "bash -lc 'CERT=${NIX_SSL_CERT_FILE:-/etc/ssl/certs/ca-bundle.crt}; export SSL_CERT_FILE=\"$CERT\"; export NODE_EXTRA_CA_CERTS=\"$CERT\"; set -a; source .env; set +a; vite dev --host 0.0.0.0 --port 3001'",
		"dev:prod": "zsh -lc 'set -a; source .env; set +a; KV_READ_ONLY_CACHE=true vite dev --host 0.0.0.0 --port 3000'",
		"build": "vite build",
		"serve": "vite preview",
		"typecheck": "tsc --noEmit",
		"test": "vitest run --passWithNoTests",
		"format": "biome format",
		"lint": "biome lint",
		"check": "biome check",
		"deploy": "wrangler deploy",
		"og": "npx vite-node --config vite.og.config.ts src/lib/open-graph/index.tsx"
	},
	"dependencies": {
		"@base-ui/react": "^1.4.1",
		"@hackernoon/pixel-icon-library": "^1.1.0",
		"@markdoc/markdoc": "^0.5.7",
		"@resvg/resvg-js": "^2.6.2",
		"@tailwindcss/vite": "^4.3.0",
		"@tanstack/react-devtools": "^0.10.2",
		"@tanstack/react-router": "^1.169.2",
		"@tanstack/react-router-devtools": "^1.166.13",
		"@tanstack/react-router-ssr-query": "^1.166.12",
		"@tanstack/react-start": "^1.167.65",
		"@tanstack/router-plugin": "^1.167.35",
		"@types/js-yaml": "^4.0.9",
		"@types/prismjs": "^1.26.6",
		"better-result": "^2.9.2",
		"fast-xml-parser": "^5.7.3",
		"js-yaml": "^4.1.1",
		"lucide-react": "^1.14.0",
		"match-sorter": "^8.3.0",
		"mermaid": "^11.14.0",
		"prismjs": "^1.30.0",
		"react": "^19.2.6",
		"react-dom": "^19.2.6",
		"recharts": "^3.8.1",
		"satori": "^0.26.0",
		"slugify": "^1.6.9",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.14",
		"@cloudflare/vite-plugin": "^1.36.3",
		"@testing-library/dom": "^10.4.1",
		"@testing-library/react": "^16.3.2",
		"@types/node": "^25.6.2",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^6.0.1",
		"jsdom": "^29.1.1",
		"typescript": "^6.0.3",
		"vite": "^8.0.11",
		"vite-node": "^6.0.0",
		"vitest": "^4.1.5",
		"web-vitals": "^5.2.0",
		"wrangler": "^4.90.0"
	}
}
