{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "kylemcd-com",
  "compatibility_date": "2025-09-02",
  "compatibility_flags": ["nodejs_compat"],
  "main": "./worker.ts",
  "routes": [
    { "pattern": "kpm.sh", "custom_domain": true },
    { "pattern": "www.kpm.sh", "custom_domain": true },
    { "pattern": "kylemcd.com", "custom_domain": true },
    { "pattern": "www.kylemcd.com", "custom_domain": true }
  ],
  "kv_namespaces": [
    {
      "binding": "APP_STORE",
      "id": "80244ef92fd3460587eca71c1c482b07",
      "remote": true
    }
  ],
  "workflows": [
    {
      "binding": "KV_REFRESH_WORKFLOW",
      "name": "kv-refresh",
      "class_name": "KvRefreshWorkflow"
    },
    {
      "binding": "STALE_MONITOR_WORKFLOW",
      "name": "stale-data-monitor",
      "class_name": "StaleDataMonitorWorkflow"
    }
  ],
  "triggers": {
    "crons": ["0,30 * * * *"]
  },
  "observability": {
    "logs": {
      "enabled": true,
      "invocation_logs": true
    }
  }
}
